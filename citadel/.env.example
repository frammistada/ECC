# --- Mentor (Claude API) ---
# Server-side key for the mentor's responses. Never exposed to the client.
ANTHROPIC_API_KEY=

# Dev only: set to 1 to run the loop without an API key.
# The mentor returns a canned placeholder, clearly not the real voice.
CITADEL_MOCK_MENTOR=

# --- Supabase (auth + database) ---
# Project Settings → API Keys. The anon/publishable key is safe to expose;
# RLS guards the data. Newer name NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY also works.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret ("service role") key: used ONLY by the payment webhook to flip
# subscription_status. The name SUPABASE_SECRET_KEY also works.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (subscription paywall) ---
STRIPE_SECRET_KEY=
# Price ID of the monthly subscription (Products → your price → API ID).
STRIPE_PRICE_ID=
# Signing secret for the webhook endpoint (/api/stripe-webhook).
STRIPE_WEBHOOK_SECRET=

# --- Accountability email (optional, item 4) ---
# Sends the "I fell short today" note to a user's chosen contact via Brevo's
# transactional API. Leave blank to keep the feature draft-only (nothing
# sends). BREVO_API_KEY: Brevo → SMTP & API → API Keys (not the SMTP key).
# ACCOUNTABILITY_FROM_EMAIL: a sender address verified in Brevo.
BREVO_API_KEY=
ACCOUNTABILITY_FROM_EMAIL=

# --- Daily reminder (web push, migration 011) ---
# VAPID keypair authenticating the server to browser push services (FCM,
# etc.). Generate once with:  npx web-push generate-vapid-keys
# The public key must ALSO be exposed to the client (same value in both
# VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY). The private key is a
# server secret — never expose it. Leave all blank to keep reminders off:
# the toggle then reports "push not configured" instead of failing oddly.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Contact for push services (a mailto: or https: URL). Falls back to
# NEXT_PUBLIC_APP_URL if unset.
VAPID_SUBJECT=
# Shared secret protecting the reminder cron endpoint. Vercel Cron sends it
# as "Authorization: Bearer <CRON_SECRET>". The endpoint fails closed if
# this is unset, so set it in production. Any long random string.
CRON_SECRET=

# --- App ---
# Public origin, used for Stripe redirect URLs. e.g. https://citadel.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
