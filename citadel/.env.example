# --- Mentor (Claude API) ---
# Server-side key for the mentor's responses. Never exposed to the client.
ANTHROPIC_API_KEY=

# Dev only: set to 1 to run the loop without an API key.
# The mentor returns a canned placeholder, clearly not the real voice.
CITADEL_MOCK_MENTOR=

# --- Supabase (auth + database) ---
# Project Settings → API Keys. The anon/publishable key is safe to expose;
# RLS guards the data. Newer name NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY also works.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret ("service role") key: used ONLY by the payment webhook to flip
# subscription_status. The name SUPABASE_SECRET_KEY also works.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (subscription paywall) ---
STRIPE_SECRET_KEY=
# Price ID of the monthly subscription (Products → your price → API ID).
STRIPE_PRICE_ID=
# Signing secret for the webhook endpoint (/api/stripe-webhook).
STRIPE_WEBHOOK_SECRET=

# --- Accountability email (optional, item 4) ---
# Sends the "I fell short today" note to a user's chosen contact via Brevo's
# transactional API. Leave blank to keep the feature draft-only (nothing
# sends). BREVO_API_KEY: Brevo → SMTP & API → API Keys (not the SMTP key).
# ACCOUNTABILITY_FROM_EMAIL: a sender address verified in Brevo.
BREVO_API_KEY=
ACCOUNTABILITY_FROM_EMAIL=

# --- App ---
# Public origin, used for Stripe redirect URLs. e.g. https://citadel.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
